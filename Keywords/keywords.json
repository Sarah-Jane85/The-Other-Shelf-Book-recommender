{
  "metadata": {
    "version": "1.0",
    "last_updated": "2026-04-20",
    "description": "Keyword whitelist for non-western fantasy book discovery project",
    "purpose": "Two-purpose keyword list: 'find' keywords are used to query APIs and scrape book sources; 'match' keywords are used as tags to power the recommender system.",
    "definition": "Non-western fantasy: fantasy that draws from non-western mythologies, folklore, spiritual systems, or cultural worldviews — written by an author with a non-western cultural background (by heritage, not necessarily by passport). Both conditions must be met.",
    "exclusions": [
      "Place names (too noisy — return too many non-fantasy results)",
      "Western mythology (Norse, Greek, Arthurian etc.)",
      "Authors of non-western heritage writing western fantasy tropes (vampires, werewolves, Tolkien-style)"
    ],
    "notes": [
      "Diaspora authors are included if the book draws from their non-western cultural heritage",
      "Popularity is tracked separately to allow the recommender to surface lesser-known books",
      "Thematic match keywords are intentionally broad — the ML layer handles disambiguation"
    ]
  },
